<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/bg">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="✕"
            android:textColor="@color/text"
            android:backgroundTint="@color/surface"
            android:padding="0dp"
            android:textSize="18sp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="إعدادات"
            android:textColor="@color/text"
            android:textSize="18sp"
            android:textStyle="bold"/>

        <View android:layout_width="44dp" android:layout_height="44dp"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="الريموت"
        android:textColor="@color/dim"
        android:textSize="12sp"
        android:gravity="end"
        android:padding="12dp"/>

    <!-- Settings Rows -->
    <LinearLayout
        android:id="@+id/rowLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="›" android:textColor="@color/dim" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="التخطيط عن بُعد" android:textColor="@color/text" android:textSize="16sp" android:gravity="end"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>

    <LinearLayout
        android:id="@+id/rowBehavior"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="›" android:textColor="@color/dim" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="السلوك عن بُعد" android:textColor="@color/text" android:textSize="16sp" android:gravity="end"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>

    <LinearLayout
        android:id="@+id/rowApps"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="›" android:textColor="@color/dim" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="إدارة التطبيقات" android:textColor="@color/text" android:textSize="16sp" android:gravity="end"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>

    <LinearLayout
        android:id="@+id/rowDevices"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="?attr/selectableItemBackground">

        <TextView android:layout_width="20dp" android:layout_height="wrap_content" android:text="›" android:textColor="@color/dim" android:textSize="20sp"/>
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="الأجهزة المتصلة" android:textColor="@color/text" android:textSize="16sp" android:gravity="end"/>
    </LinearLayout>
    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>

</LinearLayout>
